    "changelogen": "^0.6.2",
    "chart.js": "^4.5.1",
    "consola": "^3.4.2",
    "cookie": "^1.1.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.1",
    "happy-dom": "^20.10.1",
    "json-editor-vue": "^0.18.1",
    "mkdist": "^2.4.1",
    "sass": "^1.100.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "unbuild": "^3.6.1",
    "unocss": "66.7.0",
